# Local development only. Do not commit real production secrets or production database URLs.
NODE_ENV=development

# Frontend static mode remains the default when this is omitted or set to static.
# Set to api only for explicit local API-mode testing.
VITE_DATA_SOURCE=static
VITE_API_BASE_URL=http://127.0.0.1:4000

SERVER_HOST=127.0.0.1
SERVER_PORT=4000

# Backend DB mode is local-only and read-only. Use db only when a local database is running.
SERVER_DATA_MODE=disabled

# Local Docker Compose database URL.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/nte_database
CORS_ORIGIN=http://localhost:5173

# Local-only admin auth prototype. Disabled unless explicitly set to 1.
# Do not use these values for production auth.
ENABLE_LOCAL_AUTH=0
# LOCAL_AUTH_SECURE_COOKIE=0
# CONFIRM_LOCAL_ADMIN_BOOTSTRAP=1
# LOCAL_ADMIN_EMAIL=admin@example.test
# LOCAL_ADMIN_PASSWORD=Use-A-Strong-Local-Password1!

# Sitemap generation is disabled unless SITE_URL is explicitly provided at command time.
# SITE_URL=https://example.com
